{
  "name": "umami-for-socials",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted social-media analytics on Cloudflare's free tier. Umami-inspired, UTM-first.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create umami-for-socials",
    "db:apply:local": "wrangler d1 execute umami-for-socials --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute umami-for-socials --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
